generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?

  accounts   Account[]
  recipes    Recipe[]
  mealPlans  MealPlanWeek[]
  ingestions RecipeIngestion[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ─── Recipe ingestion staging ─────────────────────────────────────────────────
// Every import lands here first as a "draft". On user confirmation it becomes a Recipe.
// Raw content is ALWAYS stored and NEVER overwritten — the source of truth for re-parsing.

model RecipeIngestion {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  sourceType String  // "url" | "text"
  sourceUrl  String? // original URL if sourceType === "url"

  // Full raw source — HTML page or text paste — never modified after creation
  rawContent      String  @db.Text
  // Extracted sub-sections stored separately so Recipe.rawIngredients is clean
  rawIngredients  String  @db.Text
  rawInstructions String  @db.Text

  // Structured draft stored as JSON — all nullable fields, user corrects
  parsedDraft Json

  // Denormalised for quick filtering without JSON parsing
  confidence Float
  status     String @default("draft") // "draft" | "confirmed" | "discarded"

  // Set on confirmation
  recipeId String? @unique
  recipe   Recipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([createdAt])
}

// ─── Recipes ──────────────────────────────────────────────────────────────────

model Recipe {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?  @db.Text
  servings    Int      @default(2)
  prepMins    Int      @default(0)
  cookMins    Int      @default(0)
  source      String?  // URL or book reference

  // Verbatim input — never overwritten by the parser
  rawIngredients  String @db.Text
  rawInstructions String @db.Text

  ingredients   RecipeIngredient[]
  steps         RecipeStep[]
  mealPlanItems MealPlanItem[]
  ingestion     RecipeIngestion?   // set when created from an ingestion

  @@index([userId])
  @@index([updatedAt])
}

// ─── Canonical ingredient lookup ──────────────────────────────────────────────
// Normalised across the whole system so shopping lists can aggregate
// "AP flour", "all-purpose flour", and "plain flour" into one row.

model Ingredient {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name     String   @unique // canonical lowercase, e.g. "all-purpose flour"
  aliases  String[] // ["plain flour", "ap flour"]  — PostgreSQL native array
  category String?  // "baking" | "produce" | "dairy" | "protein" | "pantry" | "spice" | "other"

  recipeIngredients RecipeIngredient[]
}

// ─── Recipe line items ────────────────────────────────────────────────────────

model RecipeIngredient {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  recipeId  String
  recipe    Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  sortOrder Int    @default(0)

  // Immutable raw text — NEVER overwritten, always the ground truth
  rawText String

  // Human-readable name as it appears in the recipe, after qty+unit stripped.
  // e.g. "finely chopped yellow onions"
  displayName    String?
  // Canonical form for DB matching — no prep words, lowercase, singularized.
  // null when normalisation was not confident enough to attempt.
  // e.g. "onion"
  normalizedName String?

  // Quantity — primary (or minimum for ranges)
  quantity    Float?
  // Upper bound for ranges ("3–4 cloves"); null when not a range
  quantityMax Float?
  unit        String? // normalised: "g", "ml", "cup", "tsp", …

  ingredientId String?
  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id], onDelete: SetNull)

  // Prep instructions extracted from the line: "finely chopped", "to taste"
  preparationNote String?
  isOptional      Boolean @default(false)

  ingredientStates MealPlanIngredientState[]

  @@index([recipeId])
  @@index([ingredientId])
}

model RecipeStep {
  id String @id @default(cuid())

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  stepNumber   Int
  instruction  String @db.Text
  durationMins Int?

  @@unique([recipeId, stepNumber])
  @@index([recipeId])
}

// ─── Meal planning ────────────────────────────────────────────────────────────

model MealPlanWeek {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String?
  weekStart DateTime @db.Date // UTC Monday — canonical week anchor, stored as date only
  notes     String?  @db.Text

  items MealPlanItem[]

  @@unique([userId, weekStart])
  @@index([userId])
}

model MealPlanItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mealPlanWeekId String
  mealPlanWeek   MealPlanWeek @relation(fields: [mealPlanWeekId], references: [id], onDelete: Cascade)

  type     String  @default("recipe") // "recipe" | "quick"
  name     String? // display name for quick meals; optional override for recipe meals

  recipeId String?
  recipe   Recipe? @relation(fields: [recipeId], references: [id], onDelete: Restrict)

  dayOfWeek Int    // 0=Mon … 6=Sun
  mealType  String // "breakfast" | "lunch" | "dinner" | "snack"

  // Per-occurrence scaling — both stored; scaleFactor cached to avoid join during aggregation
  servings    Int
  scaleFactor Float // = servings / recipe.servings (quick meals: always 1.0)

  customNote String? @db.Text // shown instead of recipe name if set

  ingredientStates MealPlanIngredientState[]

  @@unique([mealPlanWeekId, dayOfWeek, mealType])
  @@index([mealPlanWeekId])
  @@index([recipeId])
}

// ─── Shopping list state ──────────────────────────────────────────────────────
// One row per (MealPlanItem × RecipeIngredient) — tracks shopping state
// independently per meal occurrence so the same ingredient on Monday and
// Wednesday can have different states.

enum ShoppingState {
  PENDING     // not yet reviewed
  HAVE_IT     // user already has it at home
  NEED_TO_BUY
  BOUGHT
}

model MealPlanIngredientState {
  id        String   @id @default(cuid())
  updatedAt DateTime @updatedAt

  mealPlanItemId String
  mealPlanItem   MealPlanItem @relation(fields: [mealPlanItemId], references: [id], onDelete: Cascade)

  recipeIngredientId String
  recipeIngredient   RecipeIngredient @relation(fields: [recipeIngredientId], references: [id], onDelete: Cascade)

  state ShoppingState @default(PENDING)

  // Optional user overrides — e.g. "I only need half" or a different unit
  quantityOverride Float?
  unitOverride     String?
  note             String?

  @@unique([mealPlanItemId, recipeIngredientId])
  @@index([mealPlanItemId])
}
